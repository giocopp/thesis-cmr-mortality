  file = {/Users/giorgiocoppola/Zotero/storage/4N75BHVM/Prieto-Flores - 2025 - Necropolitics at the Southern European Border Deaths and Missing Migrants on the Western Mediterran.pdf}
}

@article{punzo2024,
  title = {Beyond Borders: {{Exploring}} the Impact of {{Italian}} Migration Control Policies on {{Mediterranean}} Smuggling Dynamics and Migrant Journeys},
  shorttitle = {Beyond Borders},
  author = {Punzo, Valentina and Scaglione, Attilio},
  year = 2024,
