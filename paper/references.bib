@article{deiana2024,
  title = {Migrants at {{Sea}}: {{Unintended Consequences}} of {{Search}} and {{Rescue Operations}}},
  shorttitle = {Migrants at {{Sea}}},
  author = {Deiana, Claudio and Maheshri, Vikram and Mastrobuoni, Giovanni},
